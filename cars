function showHistoryRoleModalSuccess(data) {
    // 1. Clear the table body using jQuery's native empty container management
    let $tbody = $("#roleHistoryTableData tbody").empty();

    // 2. Define the safe element-building worker function completely outside the loop scope
    // This function takes clean text strings and maps them directly to secure, native DOM nodes
    const createNativeCells = (textValuesArray) => {
        return textValuesArray.map(textValue => {
            let td = document.createElement('td');
            td.textContent = textValue; // 100% XSS safe text assignment
            return td;
        });
    };

    // 3. Map over the data array cleanly
    let $rows = data.map(history => {
        if (!history || typeof history !== 'object') {
            return null;
        }

        // Keep your data cleanup and extraction isolated to the specific item context
        let roleId         = (history.RoleId !== null && history.RoleId !== '') ? String(history.RoleId).trim() : '';
        let roleName       = (history.RoleName !== null && history.RoleName !== '') ? String(history.RoleName).trim() : '';
        let isSystemAdmin  = (history.IsSystemAdmin !== null) ? String(history.IsSystemAdmin).trim() : '';
        let isDefaultRole  = (history.IsDefaultRole !== null && history.IsDefaultRole !== '') ? String(history.IsDefaultRole).trim() : '';
        let modifiedByName = (history.ModifiedByName !== null && history.ModifiedByName !== '') ? String(history.ModifiedByName).trim() : '';

        let modifiedDate = '';
        if (history.ModifiedDate) {
            try {
                let dateObj = new Date(history.ModifiedDate);
                if (!isNaN(dateObj.getTime())) {
                    modifiedDate = dateObj.toLocaleDateString("en-us");
                }
            } catch (e) {
                console.warn('Invalid date format:', history.ModifiedDate);
            }
        }

        // 4. Pass the local data array into our statically-allocated helper function
        const nativeCells = createNativeCells([roleId, roleName, isSystemAdmin, isDefaultRole, modifiedByName, modifiedDate]);

        // 5. Instantiate the jQuery <tr> wrapper cleanly without any inner HTML parsing or .append()
        return $('<tr>', { html: nativeCells });
    }).filter(Boolean);

    // 6. Bulk mount the pre-compiled DOM objects to the tbody
    $tbody.html($rows);

    $('#historyRoleModal').modal('show');
}
