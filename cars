function feedStateDdl() {
    try {
        $.ajax({
            type: 'GET',
            url: "/Vstar/Barcode/GetStates",
            cache: false,
            dataType: "json"
        })
        .done(function (data, textStatus, jqXHR) {
            if (data) {
                // 1. Grab the target dropdown container element natively
                const selectElement = document.getElementById('ddlAddEditBarcodeState');
                if (!selectElement) return;

                // Clear existing options securely using jQuery or native
                $(selectElement).empty();

                // 2. Add the placeholder "Select State" option using native nodes
                let defaultOption = document.createElement('option');
                defaultOption.value = "";
                defaultOption.textContent = "Select State";
                selectElement.appendChild(defaultOption);

                // 3. Loop through your response array natively
                data.forEach(text => {
                    if (!text) return;

                    // Cleanse the text source with DOMPurify
                    let rawStateCode = text.StateCode ?? '';
                    let cleanStateCode = DOMPurify.sanitize(rawStateCode, { ALLOWED_TAGS: [] });

                    // 4. Create the native option node
                    let opt = document.createElement('option');
                    opt.value = cleanStateCode;
                    opt.textContent = cleanStateCode; // 100% immune to HTML injection execution

                    // 5. Append via structural native DOM placement
                    selectElement.appendChild(opt);
                });
            }
        });
    }
    catch (e) {
        Notify.Error("Couldn't load State List");
    }
}
