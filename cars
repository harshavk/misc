var Utilities = Utilities || {};

/**
 * Safely generates a native <tr> element containing <td> cells, 
 * automatically sanitizing all inputs with DOMPurify.
 * @param {Array} columnsArray - Array of raw cell values (strings, numbers, or HTML)
 * @returns {HTMLTableRowElement} - A clean, safe <tr> DOM node
 */
Utilities.CreateSecureRow = function(columnsArray) {
    let tr = document.createElement('tr');
    
    columnsArray.forEach(cellValue => {
        let td = document.createElement('td');
        
        // Normalize null/undefined values to clean empty strings
        let safeValue = (cellValue !== null && cellValue !== undefined) ? String(cellValue).trim() : '';
        
        // Cleanse the value through DOMPurify.
        // This ensures text remains text, and any intentional HTML is stripped of XSS vectors.
        td.innerHTML = DOMPurify.sanitize(safeValue);
        
        tr.appendChild(td);
    });
    
    return tr;
};

function showHistoryRoleModalSuccess(data) {
    // 1. Get the target table body using vanilla JS for foolproof security tracing
    const tbodyElement = document.querySelector("#roleHistoryTableData tbody");
    if (tbodyElement) {
        tbodyElement.textContent = ""; // Securely flush existing content
    } else {
        return;
    }

    // 2. Loop through the rows safely
    data.forEach(history => {
        if (!history || typeof history !== 'object') return;

        // Process dynamic formatting safely locally
        let formattedDate = history.ModifiedDate ? new Date(history.ModifiedDate).toLocaleDateString("en-us") : '';

        // 3. Pass all properties as an array straight to the global secure row builder
        let tr = Utilities.CreateSecureRow([
            history.RoleId, 
            history.RoleName, 
            history.IsSystemAdmin, 
            history.IsDefaultRole, 
            history.ModifiedByName, 
            formattedDate
        ]);

        // 4. Structurally mount the completed, secure row object
        tbodyElement.appendChild(tr);
    });

    // Keep jQuery purely for bootstrap modal triggering
    $('#historyRoleModal').modal('show');
}

